<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Aquadashboard v2.3 — Mul Biotech Farms</title>
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.7.1/dist/leaflet.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.css" />
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap');
    body { margin:0; font-family:'Roboto',Arial,sans-serif; background:linear-gradient(135deg,#a2d9ff 0%,#e0f7fa 100%); position:relative; min-height:100vh; color:#00334d; user-select:none; }
    header { background:#005073; color:#fff; padding:1rem; text-align:center; font-size:1.75rem; position:relative; z-index:20; box-shadow:0 2px 14px rgba(0,80,115,0.6); text-shadow:1px 1px 3px rgba(0,0,0,0.3); }
    header small { display:block; font-weight:400; font-size:1.1rem; margin-top:0.3rem; color:#a0d8ef; font-style:italic; text-shadow:none; }
    #map { height:60vh; width:100%; box-shadow:0 4px 20px rgba(0,0,0,0.25); border-bottom:5px solid #0077aa; position:relative; z-index:10; }
    #watermark { position:fixed; bottom:10px; right:10px; font-size:0.85rem; color:rgba(0,51,77,0.4); font-weight:700; pointer-events:none; user-select:none; z-index:100; text-align:right; font-family:'Roboto',Arial,sans-serif; line-height:1.2; white-space:nowrap; }
    .cards-container { display:flex; flex-wrap:wrap; justify-content:space-between; gap:1rem; padding:1.25rem 1rem 3rem 1rem; max-width:1300px; margin:0 auto 2rem auto; position:relative; z-index:15; }
    .card { background:rgba(255,255,255,0.87); backdrop-filter:saturate(180%) blur(12px); border-radius:12px; box-shadow:0 8px 24px rgba(0,0,0,0.15); padding:1.3rem 1.2rem 1.25rem 1.2rem; margin-bottom:1rem; width:100%; max-width:395px; flex:1 1 320px; min-width:295px; color:#002d40; border:1px solid #4ca3dd; transition:box-shadow 0.3s ease; }
    .card:hover { box-shadow:0 12px 36px rgba(0,115,179,0.35); }
    .card h2 { margin-top:0; color:#004466; border-bottom:2px solid #0077bb; padding-bottom:0.4rem; font-weight:700; font-size:1.4rem; letter-spacing:0.04em; }
    .card b { color:#005486; }
    .small-note { font-size:0.78rem; color:#555; margin:0.5em 0 0 0; font-style:italic; }
    .weather-table td { padding:0.25em 0.5em; color:#004a6e; font-weight:500; font-size:1.05rem; }
    .sat-map-mini { width:100%; height:180px; border:1.5px solid #0077bb; border-radius:9px; margin-bottom:0.6em; box-shadow:0 5px 15px rgba(0,119,187,0.25); }
    ul { margin:0.4em 0 0 1.1em; padding-left:0; color:#003a59; font-weight:500; }
    li { margin-bottom:0.35em; }
    .strong-warning { color:#b71c1c; font-weight:900; font-size:0.95rem; margin-top:0.8rem; border-top:1px solid #f5c6cb; padding-top:0.6rem; }
    .badge { display:inline-block; font-size:0.72em; border-radius:5px; padding:1px 6px; margin-left:5px; font-weight:700; vertical-align:middle; }
    .badge-live { background:#d4edda; color:#155724; border:1px solid #28a745; }
    .badge-sim  { background:#fff3cd; color:#856404; border:1px solid #ffc107; }
    .badge-calc { background:#cce5ff; color:#004085; border:1px solid #004085; }
    .badge-warn { background:#f8d7da; color:#721c24; border:1px solid #dc3545; }
    .risk-low  { color:#28a745; font-weight:700; }
    .risk-med  { color:#fd7e14; font-weight:700; }
    .risk-high { color:#dc3545; font-weight:700; }
    .forecast-table { width:100%; border-collapse:collapse; font-size:0.95em; }
    .forecast-table th { background:#e0f0ff; color:#004a6e; padding:4px 6px; text-align:left; }
    .forecast-table td { padding:3px 6px; border-bottom:1px solid #d0e8f5; }
    @media (max-width:980px) { .cards-container { flex-direction:column; align-items:center; } .card { width:95vw; max-width:95vw; } }
    .disclaimer { font-size:0.85rem; color:#555; font-style:italic; padding:1rem 1rem 2rem 1rem; text-align:center; max-width:1300px; margin:0 auto 2rem auto; line-height:1.4; }
  </style>
</head>
<body oncontextmenu="return false;" oncopy="alertWarning(event)">
  <header>Aquadashboard v2.3 — Mul Biotech Farms<br /><small>a Soumodip Atanu Roy venture</small></header>
  <div id="map"></div>
  <div id="watermark">Mul Biotech Farms<br />an initiative by<br />Soumodip Atanu Roy</div>

  <div class="cards-container">

    <!-- Location -->
    <div class="card">
      <h2>📍 Location Details</h2>
      <b>Address:</b>
      <div id="address" style="margin-top:0.4em;">Click on map to get location</div>
      <div style="margin-top:0.6em;">
        <b>Latitude:</b> <span id="lat">—</span><br />
        <b>Longitude:</b> <span id="lng">—</span>
      </div>
    </div>

    <!-- Satellite Mini Map -->
    <div class="card">
      <h2>🛰️ Satellite Preview</h2>
      <div id="miniMap" class="sat-map-mini"></div>
      <div class="small-note">Source: Esri World Imagery</div>
    </div>

    <!-- LiDAR -->
    <div class="card">
      <h2>🌄 Terrain / LiDAR Proxy</h2>
      <p>Toggle <b>Hillshade (LiDAR Proxy)</b> in the map layers panel to visualise terrain elevation relief for pond site assessment.</p>
      <p style="font-size:0.88em;color:#555;">Full LiDAR integration (point cloud, DEM) planned for v2.5.</p>
    </div>

    <!-- Live Weather -->
    <div class="card">
      <h2>🌤️ Live Weather <span class="badge badge-live">Live</span></h2>
      <table class="weather-table" id="weatherTable">
        <tr><td>Temperature:</td><td id="w_temp">—</td></tr>
        <tr><td>Humidity:</td><td id="w_humidity">—</td></tr>
        <tr><td>Rain (1h):</td><td id="w_rain">—</td></tr>
        <tr><td>Cloud:</td><td id="w_cloud">—</td></tr>
        <tr><td>Wind:</td><td id="w_wind">—</td></tr>
      </table>
      <div class="small-note">Source: OpenWeatherMap</div>
    </div>

    <!-- Forecast -->
    <div class="card">
      <h2>⛅ Weather Forecast <span class="badge badge-live">Live</span></h2>
      <b>Next 24 Hours</b>
      <div id="hourlyForecast" style="margin-top:0.5em;">Click map to load...</div>
      <b style="display:block;margin-top:1em;">14-Day Summary</b>
      <div id="monthlySummary" style="margin-top:0.5em;">Click map to load...</div>
      <div class="small-note">Sources: OpenWeatherMap (hourly) · Open-Meteo (14-day)</div>
    </div>

    <!-- Water Analysis -->
    <div class="card">
      <h2>🌊 Satellite Water Analysis</h2>
      <div><b>NDWI:</b> <span id="ndwiValue">—</span></div>
      <div style="margin-top:0.5em;"><b>Water Status:</b> <span id="waterStatus">—</span></div>
      <div style="margin-top:0.5em;"><b>Turbidity:</b> <span id="turbidityStatus">—</span></div>
      <div id="ndwiNote" style="margin-top:0.6em;"></div>
      <div class="small-note">NDWI methodology from Sentinel-2 bands. Real pixel-level integration planned for v2.5. Current values are model-estimated from terrain and weather context.</div>
    </div>

    <!-- Aquaculture Suitability -->
    <div class="card">
      <h2>🐟 Aquaculture Suitability <span class="badge badge-calc">Calculated</span></h2>
      <div id="aquaRiskScore" style="margin-bottom:0.7em;"></div>
      <div id="fishSuitabilityMessage">Click on map to check suitability.</div>
      <ul id="fishSpeciesList" style="margin-top:0.6em;"></ul>
      <div id="fcrHeader" style="display:none; margin-top:0.8em;"><b>FCR &amp; Growth Rate (per year):</b></div>
      <ul id="fcrGrowthList"></ul>
      <div id="waterQualityTips" style="margin-top:0.8em;font-size:0.88em;color:#004a6e;"></div>
      <div class="strong-warning">⚠️ Data is indicative only. Always conduct on-site water quality testing before investment.</div>
    </div>

    <!-- Historical Weather -->
    <div class="card">
      <h2>📅 Historical Weather <span class="badge badge-live">Live</span></h2>
      <div id="historicalSummary">Click on map to load past 12 months of data.</div>
      <div class="small-note">Source: Open-Meteo Archive API (free, no key required)</div>
    </div>

  </div>

  <div class="disclaimer">
    <b>Disclaimer:</b> Aquadashboard v2.3 is a beta tool. All data is indicative and for planning/educational use only.
    NDWI values are model-estimated pending real Sentinel-2 integration. Field verification is mandatory before any farming or investment decision.
    Weather data © OpenWeatherMap · Forecast & Historical © Open-Meteo · Satellite imagery © Esri.
  </div>

  <script src="https://unpkg.com/leaflet@1.7.1/dist/leaflet.js"></script>
  <script src="https://unpkg.com/leaflet-control-geocoder/dist/Control.Geocoder.js"></script>
  <script>
  (() => {
    'use strict';

    const WEATHER_KEY = "6533298b91abc00d6b80047801a89c85"; // TODO: move to backend proxy

    // ── Map setup ──────────────────────────────────────────────────────────────
    const OSM = L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", { attribution:"© OpenStreetMap contributors" });
    const EsriSat = L.tileLayer("https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}", { attribution:"Tiles © Esri" });
    const NDWITiles = L.tileLayer("https://tiles.maps.eox.at/wmts/1.0.0/sentinel2cloudless-ndwi/default/{z}/{y}/{x}.png", { attribution:"© Sentinel-2 NDWI Tiles", opacity:0.7, maxZoom:18 });
    const reliefLayer = L.tileLayer("https://server.arcgisonline.com/ArcGIS/rest/services/Elevation/World_Hillshade/MapServer/tile/{z}/{y}/{x}", { attribution:"Tiles © Esri Hillshade", opacity:0.5 });

    const map = L.map("map", { center:[22.57,88.36], zoom:6, layers:[OSM] });
    L.control.layers({ "OpenStreetMap":OSM, "Satellite":EsriSat, "NDWI Layer":NDWITiles, "Hillshade (LiDAR Proxy)":reliefLayer }).addTo(map);
    if (typeof L.Control.Geocoder === "function") L.Control.geocoder().addTo(map);

    // ── Mini satellite map ─────────────────────────────────────────────────────
    let miniMap, miniMarker;
    function updateMiniMap(lat, lng) {
      if (!miniMap) {
        miniMap = L.map("miniMap", {
          attributionControl:false, zoomControl:false, dragging:false,
          scrollWheelZoom:false, doubleClickZoom:false, boxZoom:false,
          keyboard:false, tap:false, interactive:false,
          center:[lat,lng], zoom:16, layers:[EsriSat]
        });
      } else {
        miniMap.setView([lat,lng], 16);
      }
      if (miniMarker) miniMap.removeLayer(miniMarker);
      miniMarker = L.marker([lat,lng]).addTo(miniMap);
    }

    // ── Reverse geocode ────────────────────────────────────────────────────────
    async function reverseGeocode(lat, lng) {
      try {
        const res = await fetch(`https://nominatim.openstreetmap.org/reverse?lat=${lat}&lon=${lng}&format=json`);
        const data = await res.json();
        return data.display_name || "Address not found";
      } catch { return "Error fetching address"; }
    }

    // ── Live weather (OpenWeatherMap) ──────────────────────────────────────────
    async function fetchWeather(lat, lng) {
      try {
        const resp = await fetch(`https://api.openweathermap.org/data/2.5/weather?lat=${lat}&lon=${lng}&appid=${WEATHER_KEY}&units=metric`);
        if (!resp.ok) throw new Error();
        const d = await resp.json();
        const rain = d.rain?.['1h'] ? d.rain['1h']+" mm" : d.rain?.['3h'] ? d.rain['3h']+" mm (3h)" : "0 mm";
        document.getElementById("w_temp").textContent     = d.main  ? d.main.temp+" °C"      : "—";
        document.getElementById("w_humidity").textContent = d.main  ? d.main.humidity+"%"    : "—";
        document.getElementById("w_rain").textContent     = rain;
        document.getElementById("w_wind").textContent     = d.wind  ? d.wind.speed+" m/s"    : "—";
        document.getElementById("w_cloud").textContent    = d.clouds? d.clouds.all+"%"       : "—";
        return { temp: d.main?.temp ?? null, humidity: d.main?.humidity ?? 0, rain: d.rain?.['1h'] ?? 0, windSpeed: d.wind?.speed ?? 0 };
      } catch {
        document.getElementById("weatherTable").innerHTML = "<tr><td colspan='2'>Weather data unavailable</td></tr>";
        return null;
      }
    }

    // ── Hourly forecast (OpenWeatherMap) ──────────────────────────────────────
    async function fetchHourlyForecast(lat, lon) {
      try {
        const resp = await fetch(`https://api.openweathermap.org/data/2.5/forecast?lat=${lat}&lon=${lon}&appid=${WEATHER_KEY}&units=metric`);
        if (!resp.ok) throw new Error();
        const data = await resp.json();
        const next8 = data.list.slice(0, 8);
        let html = '<table class="forecast-table"><tr><th>Time</th><th>Temp (°C)</th><th>Rain (mm)</th></tr>';
        next8.forEach(item => {
          const dt = new Date(item.dt * 1000);
          const time = dt.getHours().toString().padStart(2,"0") + ":00";
          const temp = item.main.temp.toFixed(1);
          const rain = item.rain ? (item.rain["3h"] || 0).toFixed(1) : "0";
          html += `<tr><td>${time}</td><td>${temp}</td><td>${rain}</td></tr>`;
        });
        html += "</table>";
        document.getElementById("hourlyForecast").innerHTML = html;
      } catch {
        document.getElementById("hourlyForecast").innerHTML = "Hourly forecast unavailable.";
      }
    }

    // ── 14-day summary (Open-Meteo — free, replaces deprecated OWM onecall) ───
    async function fetchMonthlySummary(lat, lon) {
      try {
        const url = `https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}` +
          `&daily=temperature_2m_max,temperature_2m_min,precipitation_sum&timezone=Asia%2FKolkata&forecast_days=14`;
        const resp = await fetch(url);
        if (!resp.ok) throw new Error();
        const data = await resp.json();
        const daily = data.daily;
        const allTemps = [...daily.temperature_2m_max, ...daily.temperature_2m_min].filter(v => v != null);
        const avgTemp = (allTemps.reduce((a,b) => a+b, 0) / allTemps.length).toFixed(1);
        const totalRain = daily.precipitation_sum.filter(v => v != null).reduce((a,b) => a+b, 0).toFixed(1);
        const maxTemp = Math.max(...daily.temperature_2m_max).toFixed(1);
        const minTemp = Math.min(...daily.temperature_2m_min).toFixed(1);
        document.getElementById("monthlySummary").innerHTML = `
          <b>Avg Temp:</b> ${avgTemp} °C &nbsp;|&nbsp; <b>Range:</b> ${minTemp}–${maxTemp} °C<br>
          <b>Total Rain:</b> ${totalRain} mm
        `;
        return { avgTemp: parseFloat(avgTemp), totalRain: parseFloat(totalRain) };
      } catch {
        document.getElementById("monthlySummary").innerHTML = "14-day summary unavailable.";
        return null;
      }
    }

    // ── Historical data (Open-Meteo Archive — free, real data) ────────────────
    async function fetchHistoricalData(lat, lon) {
      document.getElementById("historicalSummary").textContent = "Loading past 12 months...";
      try {
        const end = new Date();
        const start = new Date();
        start.setFullYear(end.getFullYear() - 1);
        const fmt = d => `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
        const url = `https://archive-api.open-meteo.com/v1/archive?latitude=${lat}&longitude=${lon}` +
          `&start_date=${fmt(start)}&end_date=${fmt(end)}` +
          `&daily=temperature_2m_max,temperature_2m_min,precipitation_sum&timezone=Asia%2FKolkata`;
        const resp = await fetch(url);
        if (!resp.ok) throw new Error();
        const data = await resp.json();
        const d = data.daily;
        const avgMax = (d.temperature_2m_max.reduce((a,b) => a+b,0) / d.temperature_2m_max.length).toFixed(1);
        const avgMin = (d.temperature_2m_min.reduce((a,b) => a+b,0) / d.temperature_2m_min.length).toFixed(1);
        const totalRain = d.precipitation_sum.reduce((a,b) => a+(b||0),0).toFixed(0);
        const hotDays = d.temperature_2m_max.filter(t => t > 35).length;
        const coldDays = d.temperature_2m_min.filter(t => t < 10).length;
        document.getElementById("historicalSummary").innerHTML = `
          <table class="forecast-table">
            <tr><th>Metric</th><th>Value (past 12 mo.)</th></tr>
            <tr><td>Avg Max Temp</td><td>${avgMax} °C</td></tr>
            <tr><td>Avg Min Temp</td><td>${avgMin} °C</td></tr>
            <tr><td>Annual Rainfall</td><td>${totalRain} mm</td></tr>
            <tr><td>Days &gt; 35°C</td><td>${hotDays}</td></tr>
            <tr><td>Days &lt; 10°C</td><td>${coldDays}</td></tr>
          </table>
          <div style="font-size:0.78em;color:#666;margin-top:0.4em;">Source: Open-Meteo Archive API</div>
        `;
        return { avgMax: parseFloat(avgMax), avgMin: parseFloat(avgMin), totalRain: parseFloat(totalRain) };
      } catch {
        document.getElementById("historicalSummary").textContent = "Historical data unavailable for this location.";
        return null;
      }
    }

    // ── NDWI: model-estimated from weather context (real Sentinel-2 pending) ──
    // Real NDWI requires server-side Sentinel-2 band math — not available client-side.
    // We estimate a plausible range from rainfall and seasonal context as a placeholder.
    function estimateNDWI(rain, lat, month) {
      // Higher rain + monsoon season → more likely water present
      let base = 0.25;
      if (rain > 5) base += 0.15;
      if (rain > 10) base += 0.1;
      // Monsoon belt (Jun-Sep, lat 8-25)
      if (lat >= 8 && lat <= 25 && month >= 5 && month <= 8) base += 0.1;
      // Add small random variation (±0.05) to avoid appearing fake-precise
      base += (Math.random() - 0.5) * 0.1;
      return Math.min(Math.max(parseFloat(base.toFixed(2)), 0.05), 0.85);
    }

    function estimateTurbidity(ndwi) {
      if (ndwi > 0.55) return "Clear water (low turbidity)";
      if (ndwi > 0.30) return "Moderate turbidity";
      return "High turbidity — possible suspended solids or algae";
    }

    function getWaterStatus(ndwi) {
      if (ndwi > 0.45) return "Probable water body (medium-high confidence)";
      if (ndwi > 0.25) return "Possible water presence (low-medium confidence)";
      return "Likely land or very shallow water";
    }

    // ── Aquaculture suitability (driven by real temp + honest NDWI) ───────────
    function aquacultureSuitability(ndwi, turbidity, weather, historical) {
      const tempC = weather?.temp ?? 25;
      const lat = parseFloat(document.getElementById("lat").textContent) || 22;

      // Score components
      let score = 0;
      const factors = [], warnings = [];

      // Temperature scoring
      if (tempC >= 24 && tempC <= 30) { score += 4; factors.push("Optimal water temp"); }
      else if (tempC >= 20 && tempC <= 34) { score += 2; factors.push("Acceptable water temp"); }
      else { warnings.push("Temperature outside optimal range"); }

      // NDWI / water presence
      if (ndwi > 0.45) { score += 3; factors.push("Good water body probability"); }
      else if (ndwi > 0.25) { score += 1; warnings.push("Water body uncertain — verify on site"); }
      else { warnings.push("Insufficient water body detected"); }

      // Turbidity
      if (turbidity.includes("Clear")) { score += 3; factors.push("Clear water"); }
      else if (turbidity.includes("Moderate")) { score += 1; warnings.push("Moderate turbidity — monitor algae"); }
      else { warnings.push("High turbidity — not suitable without treatment"); }

      // Historical rainfall
      if (historical?.totalRain > 800)  { score += 1; factors.push("Adequate annual rainfall"); }
      else if (historical?.totalRain < 400) { warnings.push("Low annual rainfall — consider water sourcing"); }

      // Risk label
      const riskLabel = score >= 8 ? `<span class="risk-low">High Suitability (${score}/11)</span>`
                      : score >= 5 ? `<span class="risk-med">Moderate Suitability (${score}/11)</span>`
                      :              `<span class="risk-high">Low Suitability (${score}/11)</span>`;
      document.getElementById("aquaRiskScore").innerHTML = `<b>Suitability Score:</b> ${riskLabel}`;

      // Water quality management tips
      let tips = [];
      if (tempC > 32) tips.push("⚠️ High temp: increase aeration, reduce stocking density");
      if (turbidity.includes("High")) tips.push("⚠️ High turbidity: consider biofloc or aeration systems");
      if (weather?.humidity > 85) tips.push("💧 High humidity: monitor dissolved oxygen levels");
      if (tips.length) document.getElementById("waterQualityTips").innerHTML = "<b>Management Tips:</b><br>" + tips.join("<br>");
      else document.getElementById("waterQualityTips").innerHTML = "✅ No immediate water quality concerns detected.";

      if (score < 4) {
        return { suitable:false, message:"Conditions are not favourable for aquaculture at this location." };
      }

      // Species recommendations based on real temperature
      const species = [];
      if (tempC >= 20 && tempC <= 32) {
        species.push({ name:"IMC — Indian Major Carps 🐟", desc:"Rohu, Catla, Mrigal. Hardy, high yield, suited to ponds.", fcr:"1.5–1.8", growth:"0.8–1.2 kg/year" });
        species.push({ name:"Tilapia 🐠", desc:"Fast growing, disease resistant, tolerates poor water quality.", fcr:"1.2–1.6", growth:"0.6–1.0 kg/year" });
      }
      if (tempC >= 22 && tempC <= 30) {
        species.push({ name:"Pangasius (Basa) 🐡", desc:"High stocking density possible, popular market fish.", fcr:"1.3–1.7", growth:"1.0–1.5 kg/year" });
      }
      if (tempC >= 15 && tempC <= 25) {
        species.push({ name:"Mahseer 🐠", desc:"Suited to cleaner, flowing water bodies.", fcr:"1.6–1.9", growth:"0.6–0.9 kg/year" });
        species.push({ name:"IEC — Indian Exotic Carps 🐟", desc:"Common Carp, Silver Carp. Adaptable to varied conditions.", fcr:"1.4–1.7", growth:"0.9–1.3 kg/year" });
      }
      if (tempC >= 10 && tempC <= 18) {
        species.push({ name:"Rainbow Trout 🐡", desc:"Cold, clear, high-oxygen water required.", fcr:"1.0–1.2", growth:"0.4–0.7 kg/year" });
      }

      return { suitable: true, message: `Fish farming viable. ${factors.join(" · ")}`, species, warnings };
    }

    // ── Copyright warning ──────────────────────────────────────────────────────
    function alertWarning(e) {
      alert("🚫 Copying content is prohibited. Unauthorized use is punishable by law.");
      e.preventDefault();
      return false;
    }

    // ── Map click handler ──────────────────────────────────────────────────────
    map.on("click", async function(e) {
      const { lat, lng } = e.latlng;

      document.getElementById("lat").textContent = lat.toFixed(5);
      document.getElementById("lng").textContent = lng.toFixed(5);
      document.getElementById("address").textContent = "Loading address...";

      // Run everything in parallel where possible
      const [address, weather, , , historical] = await Promise.all([
        reverseGeocode(lat, lng),
        fetchWeather(lat, lng),
        fetchHourlyForecast(lat, lng),
        fetchMonthlySummary(lat, lng),
        fetchHistoricalData(lat, lng)
      ]);

      document.getElementById("address").textContent = address;
      updateMiniMap(lat, lng);

      // NDWI: model-estimated, clearly labelled
      const month = new Date().getMonth();
      const rain1h = weather?.rain ?? 0;
      const ndwi = estimateNDWI(rain1h, lat, month);

      document.getElementById("ndwiValue").innerHTML =
        `${ndwi} <span class="badge badge-sim">Model estimate — Sentinel-2 integration planned v2.5</span>`;
      const turbidity = estimateTurbidity(ndwi);
      document.getElementById("waterStatus").textContent = getWaterStatus(ndwi);
      document.getElementById("turbidityStatus").textContent = turbidity;
      document.getElementById("ndwiNote").innerHTML =
        `<span style="font-size:0.78em;color:#666;">NDWI is estimated from rainfall and season. On-site spectral measurement gives precise results.</span>`;

      // Aquaculture suitability
      const suitability = aquacultureSuitability(ndwi, turbidity, weather, historical);

      // Clear previous results
      document.getElementById("fishSpeciesList").innerHTML = "";
      document.getElementById("fcrGrowthList").innerHTML = "";
      document.getElementById("fcrHeader").style.display = "none";
      document.getElementById("fishSuitabilityMessage").textContent = suitability.message || "";

      if (suitability.suitable && suitability.species?.length) {
        document.getElementById("fcrHeader").style.display = "block";
        suitability.species.forEach(f => {
          const li1 = document.createElement("li");
          li1.innerHTML = `<b>${f.name}</b> — ${f.desc}`;
          document.getElementById("fishSpeciesList").appendChild(li1);

          const li2 = document.createElement("li");
          li2.innerHTML = `<b>${f.name.split("—")[0].trim()}:</b> FCR ${f.fcr} · Growth: ${f.growth}`;
          document.getElementById("fcrGrowthList").appendChild(li2);
        });
      }

      if (suitability.warnings?.length) {
        const warnDiv = document.createElement("div");
        warnDiv.style.cssText = "margin-top:0.6em;font-size:0.85em;color:#856404;";
        warnDiv.innerHTML = suitability.warnings.map(w => `⚠️ ${w}`).join("<br>");
        document.getElementById("fishSpeciesList").parentNode.insertBefore(warnDiv, document.getElementById("fishSpeciesList"));
      }
    });

  })();
  </script>
</body>
</html>
